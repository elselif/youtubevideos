/* C++ Program to Find Factorial of a number using recursion */

#include <iostream>
using namespace std;

int factorial(int number){
	if(number>1)
	{
		return number * factorial(number - 1);
	}
	else
	{
		return 1;
	}
}



int main(){
	int number;
	int choice;
	cout << " Enter any positive integer : " << endl;
	cin>>number;
	
	cout << "Factorial of " << number << " : " << factorial(number) << endl;
	
	
	
	
	return 0;
	
}
